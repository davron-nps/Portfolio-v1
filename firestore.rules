rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: grades
    // Fields:
    //   - subject: string (required)
    //   - grade: string (required)
    //   - date: string (required, ISO 8601)
    //   - uid: string (required, owner UID)
    //
    // Collection: achievements
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - date: string (required, ISO 8601)
    //   - uid: string (required, owner UID)
    //
    // Collection: diary_entries
    // Fields:
    //   - content: string (required)
    //   - date: string (required, ISO 8601)
    //   - uid: string (required, owner UID)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "altfirst11@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidGrade(data) {
      return data.keys().hasAll(['subject', 'grade', 'date', 'uid']) &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() < 100 &&
             data.grade is string && data.grade.size() > 0 && data.grade.size() < 20 &&
             data.date is string &&
             data.uid == request.auth.uid;
    }

    function isValidAchievement(data) {
      return data.keys().hasAll(['title', 'date', 'uid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.date is string &&
             data.uid == request.auth.uid;
    }

    function isValidDiaryEntry(data) {
      return data.keys().hasAll(['content', 'date', 'uid']) &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.date is string &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /grades/{gradeId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidGrade(request.resource.data);
      allow update: if isDocOwner() && isValidGrade(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /achievements/{achievementId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidAchievement(request.resource.data);
      allow update: if isDocOwner() && isValidAchievement(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /diary_entries/{entryId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidDiaryEntry(request.resource.data);
      allow update: if isDocOwner() && isValidDiaryEntry(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
